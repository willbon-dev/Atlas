---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { seoDefaults, siteConfig, siteUrl } from "../config/site";
import "../styles/global.css";
import "katex/dist/katex.min.css";

type Props = {
  title?: string;
  description?: string;
  image?: string;
};

const { title = seoDefaults.title, description = seoDefaults.description, image } = Astro.props;
const pageTitle = title === siteConfig.siteName ? title : `${title} | ${siteConfig.siteName}`;
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = image ? new URL(image, siteUrl).toString() : undefined;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.siteName} RSS`} href={`${siteConfig.basePath}/rss.xml`} />
  </head>
  <body>
    <div class="page-shell">
      <SiteHeader />
      <main>
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>

