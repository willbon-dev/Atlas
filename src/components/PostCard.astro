---
import TagList from "./TagList.astro";
import { resolveAssetPath } from "../lib/assets";

type Props = {
  title: string;
  description: string;
  href: string;
  date: Date;
  tags: string[];
  cover?: string;
};

const { title, description, href, date, tags, cover } = Astro.props;
const coverSrc = resolveAssetPath(cover);
---

<article class="post-card">
  {coverSrc && (
    <a class="post-card-cover" href={href}>
      <img src={coverSrc} alt={`${title} cover`} loading="lazy" decoding="async" />
    </a>
  )}
  <div class="post-card-body">
    <p class="meta">
      <time datetime={date.toISOString()}>{date.toLocaleDateString("zh-CN")}</time>
    </p>
    <h3>
      <a href={href}>{title}</a>
    </h3>
    <p>{description}</p>
    <TagList tags={tags} />
  </div>
</article>
