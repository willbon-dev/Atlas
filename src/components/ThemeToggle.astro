---
const options = [
  { value: "system", label: "跟随系统", icon: "◐" },
  { value: "light", label: "浅色", icon: "☀" },
  { value: "dark", label: "深色", icon: "☾" }
];
---

<div class="theme-fab" data-theme-toggle>
  <div class="theme-fab-options" role="group" aria-label="主题切换">
    {
      options.map((option) => (
        <button
          type="button"
          class="theme-fab-button"
          data-theme-option={option.value}
          aria-label={option.label}
          title={option.label}
          aria-pressed={option.value === "system" ? "true" : "false"}
        >
          <span aria-hidden="true">{option.icon}</span>
        </button>
      ))
    }
  </div>
</div>

<script is:inline>
  const storageKey = "willbon-atlas-theme";
  const themeButtons = Array.from(document.querySelectorAll("[data-theme-option]"));

  const getStoredTheme = () => {
    const stored = localStorage.getItem(storageKey);
    return stored === "light" || stored === "dark" || stored === "system" ? stored : "system";
  };

  const syncThemeControls = () => {
    const theme = getStoredTheme();
    themeButtons.forEach((button) => {
      button.setAttribute("aria-pressed", String(button.dataset.themeOption === theme));
    });
  };

  themeButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const theme = button.dataset.themeOption;
      if (!theme) return;
      localStorage.setItem(storageKey, theme);
      window.dispatchEvent(new CustomEvent("theme-change"));
      syncThemeControls();
    });
  });

  syncThemeControls();
  window.addEventListener("storage", syncThemeControls);
  window.addEventListener("theme-controls-sync", syncThemeControls);
</script>
