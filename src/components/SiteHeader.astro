---
import { siteConfig } from "../config/site";

const navItems = [
  { label: "首页", href: "/" },
  { label: "博客", href: "/blog" },
  { label: "导航", href: "/nav" },
  { label: "关于", href: "/about" }
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const basePath = siteConfig.basePath === "/" ? "" : siteConfig.basePath;
---

<header class="site-header">
  <div class="shell site-header-inner">
    <a class="brand" href={`${basePath}/`}>
      <span class="brand-mark">WA</span>
      <span class="brand-copy">
        <strong>{siteConfig.siteName}</strong>
        <small>博客与导航图谱</small>
      </span>
    </a>
    <nav class="site-nav" aria-label="主导航">
      {
        navItems.map((item) => {
          const href = `${basePath}${item.href === "/" ? "/" : item.href}`;
          const normalized = href.replace(/\/$/, "") || "/";
          const active = currentPath === normalized;
          return (
            <a class:list={["site-nav-link", { active }]} href={href}>
              {item.label}
            </a>
          );
        })
      }
    </nav>
    <div class="site-header-spacer" aria-hidden="true"></div>
  </div>
</header>
