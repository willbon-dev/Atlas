---
import { resolveAssetPath } from "../lib/assets";
import type { NavItem } from "../lib/navigation";

type Props = {
  item: NavItem;
};

const { item } = Astro.props;
const iconSrc = resolveAssetPath(item["icon-local"] ?? item["icon-remote"]);
---

<article class="nav-card">
  <div class="nav-card-header">
    {iconSrc && (
      <span class="nav-card-icon">
        <img class="nav-card-icon-image" src={iconSrc} alt="" loading="lazy" decoding="async" />
      </span>
    )}
    <h3 class="nav-card-title">
      <a href={item.url} target="_blank" rel="noreferrer">
        {item.title}
      </a>
    </h3>
  </div>
  <p class="nav-card-desc">{item.description}</p>
</article>
