---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavCard from "../components/NavCard.astro";
import { getNavigation } from "../lib/navigation";

const categories = await getNavigation();
const featuredCount = categories.reduce(
  (total, category) => total + category.links.filter((item) => item.featured).length,
  0
);
const totalLinks = categories.reduce((total, category) => total + category.links.length, 0);
---

<BaseLayout title="导航" description="Willbon Atlas 的精选导航。">
  <section class="shell nav-hero">
    <div class="nav-hero-copy">
      <p class="eyebrow">导航</p>
      <h1>精选资源图谱</h1>
      <p class="lede">
        这里收纳我会反复回访的资源入口，覆盖资料搜索、AI 学习、前端设计和文档写作。导航支持远程或本地图标，
        后续扩展时只需要维护一份结构化配置。
      </p>
    </div>
    <div class="nav-hero-stats">
      <article class="nav-stat-card">
        <strong>{totalLinks}</strong>
        <span>收录链接</span>
      </article>
      <article class="nav-stat-card">
        <strong>{categories.length}</strong>
        <span>分类数量</span>
      </article>
      <article class="nav-stat-card">
        <strong>{featuredCount}</strong>
        <span>精选推荐</span>
      </article>
    </div>
  </section>

  <section class="shell listing-page">
    <nav class="nav-category-index" aria-label="导航分类">
      {
        categories.map((category) => (
          <a href={`#${category.title}`} class="nav-category-chip">
            <span>{category.title}</span>
            <small>{category.links.length}</small>
          </a>
        ))
      }
    </nav>

    <div class="category-stack">
      {
        categories.map((category) => (
          <section class="category-panel category-panel-rich" id={category.title}>
            <div class="category-heading">
              <h2>{category.title}</h2>
              <p>{category.description}</p>
            </div>
            <div class="nav-grid">
              {category.links.map((item) => <NavCard item={item} />)}
            </div>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>