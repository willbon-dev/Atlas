---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavCard from "../components/NavCard.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { getNavigation } from "../lib/navigation";

const categories = await getNavigation();
---

<BaseLayout title="Navigation" description="Willbon Atlas 的精选导航。">
  <section class="shell listing-page">
    <SectionTitle
      eyebrow="Navigation"
      title="A curated atlas of links"
      description="支持远程或本地 icon 的结构化导航，适合持续扩展和维护。"
    />

    <div class="category-stack">
      {
        categories.map((category) => (
          <section class="category-panel">
            <div class="category-heading">
              <h2>{category.title}</h2>
              <p>{category.description}</p>
            </div>
            <div class="nav-grid">
              {category.links.map((item) => <NavCard item={item} />)}
            </div>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>
